// what if array inside array is given, how can we form a single array from it
let MixedArray = [1,2,3,4,[5,6,7,8]]
// to form a single array, which does not include array in array can be done using flat
let ans=MixedArray.flat()
//console.log(ans);
// or we can use spread 
console.log(ans.length); // prints length of given array
console.log(ans.includes(5)); // return true of particular element exists in array else return false
let v=ans.join()
console.log(v); // joins all the elements and return string type
console.log(typeof v); // type string
let i=ans.splice
let result1=ans.slice(1,3) // does not make change in original array 
// slice(start index,end index)
console.log(result1); // [ 2, 3 ]
console.log(ans); // original array remains same


let result2=ans.splice(1,2) // makes changes in original array
//splice(start index,delete count)
console.log(result2); //[ 2, 3 ]
console.log(ans); // [ 1, 4, 5, 6, 7, 8 ] removed 2 and 3 from original array


ans.push() // add element to end of and array
ans.pop() // remove element from end of an array
ans.unshift() // add element at beginning of an array
ans.shift() // remove element from beginning of an arary

